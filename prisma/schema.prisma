generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String            @id @default(cuid())
  name                 String?
  email                String            @unique
  academicId           String            @unique
  passwordHash         String
  nameAr               String?
  isApproved           Boolean           @default(false)
  emailVerified        DateTime?
  image                String?
  role                 Role              @default(STUDENT)
  emailNotifications   Boolean           @default(true)
  siteNotifications    Boolean           @default(true)
  language             String            @default("ar")
  theme                String            @default("light")
  lastCheckedNewStudentsAt DateTime       @default(now())
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  accounts             Account[]
  uploadedCertificates Certificate[]     @relation("CertificateUploader")
  certificate          Certificate?
  updatedSteps         CertificateStep[] @relation("StepUpdater")
  certificateSteps     CertificateStep[] @relation("StudentSteps")
  reviewedDocuments    Document[]        @relation("DocumentReviewer")
  documents            Document[]        @relation("StudentDocuments")
  reviewedForms        GraduationForm[]  @relation("FormReviewer")
  graduationForm       GraduationForm?
  sentNotifications    Notification[]    @relation("NotificationSender")
  notifications        Notification[]    @relation("UserNotifications")
  sessions             Session[]
  studentProfile       StudentProfile?
  assignedTodos        Todo[]            @relation("StaffTodos")
}

model Todo {
  id          String   @id @default(cuid())
  title       String
  completed   Boolean  @default(false)
  staffId     String
  staff       User     @relation("StaffTodos", fields: [staffId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model StudentProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  studentCardNumber String?
  major             String?
  graduationYear    Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  gpa               Float?
  nationalId        String?
  phone             String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GraduationForm {
  id           String               @id @default(cuid())
  userId       String               @unique
  status       GraduationFormStatus @default(DRAFT)
  submittedAt  DateTime?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  reviewer     User?                @relation("FormReviewer", fields: [reviewedById], references: [id])
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id              String         @id @default(cuid())
  userId          String
  documentType    DocumentType
  label           String
  fileName        String
  filePath        String
  fileSize        Int
  mimeType        String
  status          DocumentStatus @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  reviewer        User?          @relation("DocumentReviewer", fields: [reviewedById], references: [id])
  user            User           @relation("StudentDocuments", fields: [userId], references: [id], onDelete: Cascade)
}

model CertificateStep {
  id                  String     @id @default(cuid())
  userId              String
  label               String
  order               Int
  status              StepStatus @default(PENDING)
  updatedById         String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  isModifiedByStudent Boolean    @default(false)
  updatedBy           User?      @relation("StepUpdater", fields: [updatedById], references: [id])
  user                User       @relation("StudentSteps", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, order])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  sentById  String?
  createdAt DateTime @default(now())
  sentBy    User?    @relation("NotificationSender", fields: [sentById], references: [id])
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationTemplate {
  id        String   @id @default(cuid())
  title     String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Certificate {
  id           String   @id @default(cuid())
  userId       String   @unique
  fileName     String
  filePath     String
  uploadedById String?
  createdAt    DateTime @default(now())
  uploadedBy   User?    @relation("CertificateUploader", fields: [uploadedById], references: [id])
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Analytics {
  id        String   @id @default(cuid())
  type      String
  name      String
  value     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

enum Role {
  STUDENT
  ADMIN
  STAFF
}

enum GraduationFormStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  NEEDS_CONFIRMATION
  APPROVED
  REJECTED
}

enum DocumentType {
  PASSPORT
  PERSONAL_PHOTO
  HIGH_SCHOOL_CERT
  NATIONAL_ID
  OTHER
}

enum DocumentStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  NEEDS_VERIFICATION
  MODIFIED
  REJECTED
}
